# ──────────────────────────────────────────────────────────────────────────────
# Outtlyr / IntentTerminal V2.1 — environment template
# Copy to backend/.env and fill in. NEVER commit backend/.env.
# ──────────────────────────────────────────────────────────────────────────────

# ─── LLM provider — GCP Vertex AI ONLY (no AI Studio, no OpenRouter) ─────────
# The Data Selection Module routes all LLM calls through Vertex AI Gemini.
# `_llm.py` reads VERTEX_AI_API_KEY ONLY — other LLM env vars below are
# for the host repo's other stages (Hypothesis Engine, Intake), not us.
VERTEX_AI_API_KEY=                    # REQUIRED for L2 synth + L6 triage
HYPOTHESIS_PROVIDER=gcp_gemini
GCP_GEMINI_RPM=60

# Other LLM providers — used by HOST repo only, not this module. Safe to
# leave empty if this module is the only thing running.
OPENROUTER_API_KEY=
GEMINI_API_KEY=                       # AI Studio — NOT used by this module
DEEPSEEK_API_KEY=

# ─── Search backends (Data Selection Module) ────────────────────────────────
# Preference order: Brave → DuckDuckGo → Headless Google
BRAVE_API_KEY=                        # required for primary search tier
USE_DUCKDUCKGO=1                      # 1 enables DDG fallback; 0 disables
ENABLE_SERPAPI=0                      # placeholder switch — backend is a stub
SERPAPI_KEY=                          # only used when ENABLE_SERPAPI=1 + impl wired
SERPER_API_KEY=                       # serper.dev (used by legacy scout.py)

# ─── Headless Chromium tuning (Change #2 — Google-priority + anti-CAPTCHA) ──
# Parallel Chromium contexts. Change #2 default = 1 (was 3) — bursty parallel
# requests from one IP get flagged fastest. Bump only if you've validated low
# CAPTCHA rate with your IP/proxy setup.
HEADLESS_CONCURRENCY=1
# Seconds the backend self-disables for after a CAPTCHA is detected.
# Change #2 default = 300s (5 min, was 30s). Google flags IPs for hours
# after a CAPTCHA hit; 30s wasn't enough to clear the signal.
HEADLESS_CAPTCHA_COOLDOWN_SEC=300

# ─── Channel API keys (wired in later steps) ────────────────────────────────
YOUTUBE_API_KEY=                      # Step 6 — YT Shorts + long-form
REDDIT_CLIENT_ID=                     # Step 10 — PRAW (optional; Brave fallback works without)
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=outtlyr/0.1

# ─── Step 14 — cost meter + memory store ─────────────────────────────────────
# Per-hypothesis $ ceiling (Gemini-token-based). Raise for production batches,
# lower for dev. Hard-stop fires CostLimitExceeded.
OUTTLYR_COST_CAP_USD=0.50
# Where job/batch snapshots persist across server restarts. Defaults to
# <module-root>/.memory/.
# OUTTLYR_MEMORY_DIR=
